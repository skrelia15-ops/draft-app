# Copy to `.env` and fill in real values. EXPO_PUBLIC_* vars are inlined into
# the JS bundle at build time, so they must be present when you build/start.

# ── Supabase ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Google Maps (native SDK) ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Google Sign-In ───────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials.
#   IOS_CLIENT_ID  : the iOS OAuth client id   (xxxx.apps.googleusercontent.com)
#   WEB_CLIENT_ID  : the Web OAuth client id   (xxxx.apps.googleusercontent.com)
#   IOS_URL_SCHEME : the iOS client id REVERSED (com.googleusercontent.apps.xxxx)
# The WEB client id must also be set as Supabase's Google provider "Client ID".
# Until IOS_URL_SCHEME is set, the google-signin config plugin is skipped and
# the Google button stays inert (Apple Sign In is unaffected).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# ── Apple Sign-In ────────────────────────────────────────────────────────
# OFF by default: the button is hidden and the native entitlement is skipped,
# so no paid Apple Developer membership is needed to build/run. Set to "true"
# (and rebuild) once you have: Apple Developer "Sign in with Apple" capability,
# a Services ID + key, and the Apple provider configured in Supabase.
# Note: App Store review requires Apple Sign In whenever Google sign-in is shown.
EXPO_PUBLIC_APPLE_AUTH_ENABLED=false
